# ─── Google (Calendar + Gmail) ────────────────────────────────────────────────
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: https://YOUR-VERCEL-URL/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# After first sign-in, these are stored automatically — leave blank initially
GOOGLE_REFRESH_TOKEN=

# ─── Microsoft Outlook ────────────────────────────────────────────────────────
# Get these from https://portal.azure.com → App registrations → New registration
# Redirect URI: https://YOUR-VERCEL-URL/api/auth/outlook/callback
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=https://your-app.vercel.app/api/auth/outlook/callback
OUTLOOK_REFRESH_TOKEN=

# ─── Calendly ─────────────────────────────────────────────────────────────────
# Get from https://calendly.com/integrations/api_webhooks → Personal Access Token
CALENDLY_API_KEY=
CALENDLY_USER_URI=

# ─── Todoist ──────────────────────────────────────────────────────────────────
# Get from https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# ─── Person Research (web search) ────────────────────────────────────────────
# Get from https://serper.dev (free tier: 2,500 searches/month)
SERPER_API_KEY=

# ─── Vercel KV (database) ─────────────────────────────────────────────────────
# Auto-filled by Vercel when you add a KV store in your project dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Push Notifications (VAPID) ───────────────────────────────────────────────
# Generate these once by running: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=rg@rachaelgoldfarb.org
# This must be the same as VAPID_PUBLIC_KEY — prefix with NEXT_PUBLIC_ so the browser can read it
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
# Set to any long random string — used to verify webhook authenticity
WEBHOOK_SECRET=your-random-secret-here
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Vercel auto-generates this when you add a Cron job — leave blank
CRON_SECRET=
